# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required for the sample experiment: Hugging Face token
HF_TOKEN=your-hf-token-here

# Optional: Hugging Face model to use (default: mistralai/Mistral-7B-Instruct-v0.3)
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Optional: number of concurrent eval requests (default: 5)
# EVAL_CONCURRENCY=5
